<div class="max-w-xl mx-auto bg-white p-6 rounded shadow space-y-4">

  <%= form_with(model: vault) do |form| %>

    <% if vault.errors.any? %>
      <div class="bg-red-100 text-red-700 p-3 rounded">
        <%= vault.errors.full_messages.join(", ") %>
      </div>
    <% end %>

    <div>
      <%= form.label :site, class: "block font-medium" %>
      <%= form.text_field :site, class: "w-full border p-2 rounded" %>
    </div>

    <div>
      <%= form.label :url, class: "block font-medium" %>
      <%= form.text_field :url, class: "w-full border p-2 rounded" %>
    </div>

    <div>
      <%= form.label :login, class: "block font-medium" %>
      <%= form.text_field :login, class: "w-full border p-2 rounded" %>
    </div>

    <div>
      <%= form.label :password, class: "block font-medium" %>
      <%= form.text_field :password, class: "w-full border p-2 rounded" %>
    </div>

    <div>
      <%= form.submit class: "bg-blue-600 text-white px-4 py-2 rounded" %>
    </div>

  <% end %>

</div>