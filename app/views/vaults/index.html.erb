<div class="max-w-5xl mx-auto">
  <h1 class="text-3xl font-bold mb-6">Vaults</h1>

  <div class="mb-4">
    <%= link_to "New Vault", new_vault_path,
      class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
  </div>

  <table class="w-full bg-white shadow rounded-lg overflow-hidden">
    <thead class="bg-gray-200 text-left">
      <tr>
        <th class="p-3">Site</th>
        <th class="p-3">URL</th>
        <th class="p-3">Login</th>
        <th class="p-3">Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @vaults.each do |vault| %>
        <tr class="border-t">
          <td class="p-3"><%= vault.site %></td>
          <td class="p-3"><%= vault.url %></td>
          <td class="p-3"><%= vault.login %></td>
          <td class="p-3 space-x-2">
            <%= link_to "Edit", edit_vault_path(vault),
              class: "text-blue-600 hover:underline" %>

            <%= link_to "Delete", vault,
              method: :delete,
              data: { confirm: "Are you sure?" },
              class: "text-red-600 hover:underline" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>