<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Vault" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
<header style="background:#1a1a2e; color:#fff; padding:12px 20px;">
  <div style="max-width:1200px; margin:0 auto; display:flex; justify-content:space-between; align-items:center;">
    <span style="font-weight:bold; font-size:18px;">🔐 Vault</span>
    <div>
      <% if user_signed_in? %>
        <span style="font-size:14px; margin-right:15px; color:#aaa;"><%= current_user.email %></span>
        <%= button_to "Logout", destroy_user_session_path, method: :delete, 
            style: "background:#dc3545; border:none; color:#fff; padding:5px 15px; border-radius:4px; cursor:pointer; margin-right:10px;" %>
        <%= button_to "Delete Account", user_registration_path, method: :delete, 
            data: { confirm: "Are you sure? This will permanently delete your account and all your vaults." },
            style: "background:#6c757d; border:none; color:#fff; padding:5px 15px; border-radius:4px; cursor:pointer;" %>
      <% else %>
        <%= link_to "Login", new_user_session_path, 
            style: "background:#0d6efd; color:#fff; padding:5px 15px; border-radius:4px; text-decoration:none;" %>
      <% end %>
    </div>
  </div>
</header>

    <!-- Flash Messages (unchanged) -->
    <% if notice %>
      <div style="max-width:1200px; margin:15px auto 0; padding:10px; background:#d4edda; border:1px solid #c3e6cb; border-radius:4px; color:#155724;">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div style="max-width:1200px; margin:10px auto 0; padding:10px; background:#f8d7da; border:1px solid #f5c6cb; border-radius:4px; color:#721c24;">
        <%= alert %>
      </div>
    <% end %>

    <main style="max-width:1200px; margin:20px auto; padding:0 20px;">
      <%= yield %>
    </main>
  </body>
</html>